# 服务器配置
PORT=3001

# JWT 密钥（用于认证）
JWT_SECRET=your-jwt-secret-key-change-in-production

# 管理员密码
ADMIN_PASSWORD=your-admin-password-change-in-production

# 推送令牌（用于推送 API）
PUSH_TOKEN=your-push-token-change-in-production

# VAPID 密钥（用于 Web Push）
# 使用以下命令生成：
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key-change-in-production
VAPID_PRIVATE_KEY=your-vapid-private-key-change-in-production
